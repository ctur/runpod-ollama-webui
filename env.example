# =============================================================================
# RunPod Ollama + Open WebUI — Environment Variables
# Copy the variables you need into RunPod Template → Environment Variables
# =============================================================================

# ── Ollama: Model ──
# Comma-separated list of models to auto-pull on startup
# Leave empty to skip auto-pull
OLLAMA_MODEL=llama3.2

# ── Ollama: Server ──
OLLAMA_HOST=0.0.0.0:11434
OLLAMA_KEEP_ALIVE=5m
OLLAMA_NUM_PARALLEL=4
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_FLASH_ATTENTION=1

# ── Ollama: GPU ──
NVIDIA_VISIBLE_DEVICES=all
# OLLAMA_NUM_GPU=         # leave unset for auto
# OLLAMA_MAX_VRAM=        # leave unset for no limit
# OLLAMA_GPU_OVERHEAD=    # leave unset for no reservation

# ── Open WebUI: Connection ──
OLLAMA_BASE_URL=http://127.0.0.1:11434
PORT=8080
ENABLE_OLLAMA_API=True

# ── Open WebUI: Auth ──
WEBUI_AUTH=True
ENABLE_SIGNUP=True
DEFAULT_USER_ROLE=pending
# WEBUI_ADMIN_EMAIL=      # set for headless admin creation
# WEBUI_ADMIN_PASSWORD=   # set for headless admin creation

# ── Open WebUI: General ──
# WEBUI_SECRET_KEY=       # set for consistent sessions across restarts
# DEFAULT_MODELS=         # auto-set from OLLAMA_MODEL if empty
DEFAULT_LOCALE=en
ANONYMIZED_TELEMETRY=false
DO_NOT_TRACK=true
